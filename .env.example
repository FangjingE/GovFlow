# GovFlow 运行配置（复制为 .env 后按需修改）
GOVFLOW_ENV=dev
# 未来：OpenAI 兼容端点（本地 vLLM / Ollama）
# GOVFLOW_LLM_BASE_URL=http://127.0.0.1:8001/v1
# GOVFLOW_LLM_API_KEY=unused
# GOVFLOW_LLM_MODEL=qwen2.5-14b-instruct
# 政务兜底电话（P0 展示用）
GOVFLOW_DEFAULT_HOTLINE=12345
# 答案审核：pass_through（默认）| grounded（额外拒绝证据中未出现的长数字）
# GOVFLOW_ANSWER_AUDITOR_MODE=grounded
# GOVFLOW_ANSWER_AUDITOR_MIN_ANSWER_LENGTH=20
