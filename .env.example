# GovFlow 运行配置（复制为 .env 后按需修改）
GOVFLOW_ENV=dev
# LLM：默认 mock。接入 DeepSeek：取消下行注释并填写 key
# GOVFLOW_LLM_PROVIDER=deepseek
# GOVFLOW_LLM_API_KEY=
# GOVFLOW_LLM_BASE_URL=https://api.deepseek.com
# GOVFLOW_LLM_MODEL=deepseek-chat
# 政务兜底电话（P0 展示用）
GOVFLOW_DEFAULT_HOTLINE=12345
# 答案审核：pass_through（默认）| grounded（额外拒绝证据中未出现的长数字）
# GOVFLOW_ANSWER_AUDITOR_MODE=grounded
# GOVFLOW_ANSWER_AUDITOR_MIN_ANSWER_LENGTH=20
