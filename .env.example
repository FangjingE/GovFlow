# GovFlow（PostgreSQL + pgvector）
GOVFLOW_ENV=dev
GOVFLOW_DATABASE_URL=postgresql://govflow:govflow@127.0.0.1:5433/govflow
# vector（默认）：仅向量检索 | text：pg_trgm + ILIKE（调试）
# GOVFLOW_RETRIEVAL_MODE=vector
# ivfflat 召回探测桶数（越大越准，越慢；建议先 100）
# GOVFLOW_VECTOR_IVFFLAT_PROBES=100
# 文本检索最低相似度阈值（0~1）
# GOVFLOW_TEXT_MATCH_MIN_SCORE=0.05
GOVFLOW_DEFAULT_HOTLINE=12345
GOVFLOW_EMBEDDING_PROVIDER=local
GOVFLOW_EMBEDDING_LOCAL_MODEL=BAAI/bge-base-zh-v1.5
GOVFLOW_EMBEDDING_LOCAL_DEVICE=auto
GOVFLOW_EMBEDDING_LOCAL_FILES_ONLY=true
