        "service_object": null,
        "promise_days": 3,
        "legal_days": 20,
        "on_site_times": 0,
        "is_charge": false,
        "accept_condition": "《中华人民共和国保守国家秘密法》（1988年9月5日主席令第6号公布，2010年4月29日主席令第28号修改）第三章第二十八条：互联网及其他公共信息网络运营商、服务商应当配合公安机关、国家安全机关、检察机关对泄密案件进行调查；发现利用互联网及其他公共信息网络发布的信息涉及泄露国家秘密的，应当立即停止传输，保存有关记录，向公安机关、国家安全机关或者保密行政管理部门报告；应当根据公安机关、国家安全机关或者保密行政管理部门的要求，删除涉及泄露国家秘密的信息。...展开",
        "general_scope": "全市",
